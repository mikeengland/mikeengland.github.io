---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-slate-50">
		<Header />
		<main class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
			<!-- Page header -->
			<div class="mb-10">
				<p class="text-blue-600 text-xs font-bold uppercase tracking-widest mb-2">Writing</p>
				<h1 class="text-4xl font-bold text-slate-900 mb-3">Blog</h1>
				<p class="text-slate-500 text-lg m-0">Thoughts on software, technology, and ideas.</p>
			</div>

			<!-- Post list -->
			<div class="space-y-3">
				{posts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="group flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 sm:gap-6 bg-white rounded-xl border border-slate-200 border-l-[3px] border-l-slate-100 hover:border-l-blue-500 hover:border-slate-200 hover:shadow-md transition-all duration-200 no-underline hover:no-underline px-6 py-5"
					>
						<div class="flex-1 min-w-0">
							<h2 class="font-bold text-slate-900 text-base sm:text-lg leading-snug mb-1.5 group-hover:text-blue-600 transition-colors duration-150 break-words">
								{post.data.title}
							</h2>
							{post.data.description && (
								<p class="text-slate-400 text-sm leading-relaxed line-clamp-2 m-0 break-words">
									{post.data.description}
								</p>
							)}
						</div>
						<div class="shrink-0 flex flex-row sm:flex-col items-center sm:items-end justify-between sm:justify-start gap-2 sm:pt-0.5">
							<time
								class="text-xs text-slate-400 font-medium tabular-nums"
								datetime={post.data.pubDate.toISOString()}
							>
								<FormattedDate date={post.data.pubDate} />
							</time>
							<span class="text-slate-300 group-hover:text-blue-500 group-hover:translate-x-1 transition-all duration-200 text-lg leading-none">
								&rarr;
							</span>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
