---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_ROLE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-slate-50">
		<Header />

		<!-- Hero -->
		<section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white px-6 py-20 sm:py-28 overflow-hidden">
			<!-- Radial blue glow -->
			<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 55% at 50% -10%, rgba(37,99,235,0.4) 0%, transparent 65%)"></div>
			<!-- Subtle dot grid -->
			<div class="absolute inset-0 pointer-events-none opacity-[0.035]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;"></div>
			<div class="relative max-w-3xl mx-auto">
				<p class="text-slate-400 text-sm font-medium mb-2">Hello, I'm</p>
				<h1 class="text-5xl sm:text-6xl font-bold mb-3 leading-tight bg-gradient-to-r from-white via-blue-50 to-blue-200 bg-clip-text text-transparent">{SITE_AUTHOR}</h1>
				<p class="text-blue-400 font-semibold text-lg mb-6 tracking-wide">{SITE_ROLE}</p>
				<p class="text-slate-300 text-lg leading-relaxed max-w-xl mb-8">
					Currently working on AI/ML applications and infrastructure.
					I enjoy writing about technology and engineering.
					Based in London.
				</p>
				<div class="flex gap-3 flex-wrap">
					<a
						href="/cv"
						class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors duration-150 no-underline hover:no-underline text-sm"
					>
						View CV
					</a>
					<a
						href="/blog"
						class="inline-flex items-center gap-2 border border-white/25 hover:border-white/50 hover:bg-white/5 text-slate-200 font-semibold px-5 py-2.5 rounded-lg transition-all duration-150 no-underline hover:no-underline text-sm"
					>
						Read Blog &rarr;
					</a>
				</div>
			</div>
		</section>

		<!-- Recent posts -->
		<main class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
			<div class="flex items-center justify-between mb-6">
				<p class="text-blue-600 text-xs font-bold uppercase tracking-widest m-0">Recent Writing</p>
				<a
					href="/blog"
					class="text-sm text-slate-500 hover:text-blue-600 font-medium transition-colors duration-150 no-underline hover:no-underline"
				>
					View all &rarr;
				</a>
			</div>

			<div class="grid sm:grid-cols-3 gap-4">
				{posts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="group relative block w-full min-w-0 bg-white rounded-xl border border-slate-200 p-5 hover:border-blue-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 no-underline hover:no-underline overflow-hidden"
					>
						<!-- Gradient wash on hover -->
						<div class="absolute inset-0 bg-gradient-to-br from-blue-50/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl pointer-events-none"></div>
						<div class="relative">
							<p class="text-xs font-semibold text-blue-600 uppercase tracking-wider mb-3 m-0">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h2 class="font-bold text-slate-900 text-base leading-snug mb-2 group-hover:text-blue-700 transition-colors duration-150 break-words">
								{post.data.title}
							</h2>
							{post.data.description && (
								<p class="text-slate-400 text-sm leading-relaxed line-clamp-3 m-0 break-words">
									{post.data.description}
								</p>
							)}
						</div>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>
